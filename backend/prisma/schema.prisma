generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  MERCHANT
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum NodeRunStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELED
}

enum PaymentChannel {
  WECHAT
  ALIPAY
}

enum PaymentStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
}

enum LedgerType {
  RECHARGE
  RESERVE
  CONSUME
  RELEASE
  REFUND
  ADJUSTMENT
}

model User {
  id             String   @id @default(uuid())
  countryCode    String   @default("+86")
  phone          String   @unique
  nickname       String
  avatarUrl      String?
  roles          Role[]
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  session        Session?
  pointAccount   PointAccount?
  workflows      Workflow[]
  runs           WorkflowRun[]
  payments       PaymentOrder[]
  ledger         PointLedger[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @unique
  tokenHash String   @unique
  version   Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmsVerificationCode {
  id          String    @id @default(uuid())
  countryCode String    @default("+86")
  phone       String
  codeHash    String
  role        Role
  attempts    Int       @default(0)
  consumedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  @@index([countryCode, phone, createdAt])
}

model Workflow {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  definition  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  versions    WorkflowVersion[]
  runs        WorkflowRun[]
  @@index([ownerId, updatedAt])
}

model WorkflowVersion {
  id         String   @id @default(uuid())
  workflowId String
  number     Int
  definition Json
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  runs       WorkflowRun[]
  @@unique([workflowId, number])
}

model WorkflowRun {
  id          String      @id @default(uuid())
  workflowId  String
  versionId   String
  userId      String
  status      RunStatus   @default(PENDING)
  cost        Int         @default(0)
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime    @default(now())
  workflow    Workflow    @relation(fields: [workflowId], references: [id])
  version     WorkflowVersion @relation(fields: [versionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  nodeRuns    NodeRun[]
  reservation PointReservation?
  @@index([userId, createdAt])
}

model NodeRun {
  id         String        @id @default(uuid())
  runId      String
  nodeKey    String
  nodeType   String
  status     NodeRunStatus @default(PENDING)
  input      Json?
  output     Json?
  error      String?
  attempt    Int           @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime      @default(now())
  run        WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  @@unique([runId, nodeKey])
  @@index([runId, status])
}

model PointAccount {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  frozen    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointLedger {
  id          String     @id @default(uuid())
  userId      String
  type        LedgerType
  amount      Int
  balanceAfter Int
  referenceId String?
  description String?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([type, referenceId])
  @@index([userId, createdAt])
}

model PointReservation {
  id        String      @id @default(uuid())
  runId     String      @unique
  userId    String
  amount    Int
  settled   Int         @default(0)
  released  Int         @default(0)
  createdAt DateTime    @default(now())
  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model PaymentOrder {
  id            String         @id @default(uuid())
  orderNo       String         @unique
  userId        String
  channel       PaymentChannel
  status        PaymentStatus  @default(PENDING)
  amountFen     Int
  points        Int
  qrUrl         String?
  providerTradeNo String?      @unique
  paidAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  events        PaymentEvent[]
  @@index([userId, createdAt])
}

model PaymentEvent {
  id        String       @id @default(uuid())
  orderId   String
  eventKey  String       @unique
  payload   Json
  createdAt DateTime     @default(now())
  order     PaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

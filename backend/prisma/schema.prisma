generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  MERCHANT
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum NodeRunStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELED
}

enum AiInvocationStatus {
  SUBMITTING
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PaymentChannel {
  WECHAT
  ALIPAY
}

enum PaymentStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
}

enum LedgerType {
  RECHARGE
  RESERVE
  CONSUME
  RELEASE
  REFUND
  ADJUSTMENT
}

enum AssetStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum AssetSource {
  UPLOAD
  AI_GENERATED
  REMOTE_IMPORT
}

enum ProductImageRole {
  COVER
  DETAIL
  REFERENCE
}

enum CharacterImageAngle {
  AVATAR
  FRONT
  LEFT
  RIGHT
  HALF_BODY
  FULL_BODY
  OTHER
}

model User {
  id                 String           @id @default(uuid())
  countryCode        String           @default("+86")
  phone              String           @unique
  nickname           String
  avatarUrl          String?
  roles              Role[]
  profileInitialized Boolean?
  sessionVersion     Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  session            Session?
  pointAccount       PointAccount?
  workflows          Workflow[]
  runs               WorkflowRun[]
  payments           PaymentOrder[]
  ledger             PointLedger[]
  assetFiles         AssetFile[]
  products           ProductAsset[]
  characters         CharacterAsset[]
  aiInvocations      AiModelInvocation[]
}

/// 商品三级分类；通过 parentId 自关联组成目录树。
model ProductCategory {
  id        String            @id @default(uuid())
  code      String            @unique
  name      String
  level     Int
  parentId  String?
  sortOrder Int               @default(0)
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parent    ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  ProductCategory[] @relation("ProductCategoryTree")
  products  ProductAsset[]

  @@unique([parentId, name])
  @@index([parentId, active, sortOrder])
  @@index([level, active, sortOrder])
}

/// 可被商品、形象和工作流复用的媒体文件记录。
model AssetFile {
  id                  String           @id
  ownerId             String?
  originalName        String
  mediaType           String
  mimeType            String
  size                Int
  source              AssetSource      @default(UPLOAD)
  createdAt           DateTime         @default(now())
  deletedAt           DateTime?
  owner               User?            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  productImages       ProductImage[]
  characterImages     CharacterImage[]
  characterReferences CharacterAsset[] @relation("CharacterReference")

  @@index([ownerId, createdAt])
  @@index([deletedAt])
}

model ProductAsset {
  id              String          @id @default(uuid())
  ownerId         String
  categoryId      String
  title           String
  sellingPoints   Json
  audienceProfile String?
  description     String?
  sourceUrl       String?
  tags            Json
  status          AssetStatus     @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images          ProductImage[]

  @@index([ownerId, status, updatedAt])
  @@index([categoryId, status])
  @@index([deletedAt])
}

model ProductImage {
  id        String           @id @default(uuid())
  productId String
  fileId    String
  role      ProductImageRole @default(DETAIL)
  sortOrder Int              @default(0)
  product   ProductAsset     @relation(fields: [productId], references: [id], onDelete: Cascade)
  file      AssetFile        @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([productId, fileId])
  @@index([fileId])
}

model CharacterAsset {
  id               String           @id @default(uuid())
  ownerId          String
  referenceFileId  String?
  name             String
  description      String?
  generationPrompt String?
  modelId          String?
  voiceId          String?
  voiceName        String?
  tags             Json
  source           AssetSource      @default(UPLOAD)
  isDefault        Boolean          @default(false)
  status           AssetStatus      @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  referenceFile    AssetFile?       @relation("CharacterReference", fields: [referenceFileId], references: [id], onDelete: Restrict)
  images           CharacterImage[]

  @@index([ownerId, status, updatedAt])
  @@index([ownerId, isDefault])
  @@index([referenceFileId])
  @@index([deletedAt])
}

model CharacterImage {
  id          String              @id @default(uuid())
  characterId String
  fileId      String
  angle       CharacterImageAngle @default(OTHER)
  sortOrder   Int                 @default(0)
  character   CharacterAsset      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  file        AssetFile           @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@unique([characterId, fileId])
  @@index([fileId])
}

model RechargePackage {
  id        String         @id @default(uuid())
  code      String         @unique
  name      String
  keys      Int
  amountFen Int
  active    Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  orders    PaymentOrder[]

  @@index([active, sortOrder])
}

model AiModel {
  id              String              @id @default(uuid())
  providerModelId String              @unique
  name            String
  vendor          String
  capability      String
  description     String?
  baseKeys        Int                 @default(0)
  fields          Json                @default("[]")
  pricingRules    Json                @default("[]")
  outputSchema    Json?
  active          Boolean             @default(false)
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  invocations     AiModelInvocation[]

  @@index([capability, active, sortOrder])
  @@index([vendor])
}

model AiModelInvocation {
  id                String             @id @default(uuid())
  modelId           String
  userId            String?
  workflowRunId     String?
  nodeRunId         String?
  providerTaskUuid  String?
  status            AiInvocationStatus @default(SUBMITTING)
  requestParams     Json
  pricingSnapshot   Json
  providerResponse  Json?
  output            Json?
  estimatedKeys     Int
  chargedKeys       Int
  refundedKeys      Int                @default(0)
  providerAmountUsd Decimal?           @db.Decimal(12, 6)
  errorMessage      String?
  attempt           Int                @default(1)
  submittedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  model             AiModel            @relation(fields: [modelId], references: [id], onDelete: Restrict)
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  workflowRun       WorkflowRun?       @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  nodeRun           NodeRun?           @relation(fields: [nodeRunId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([modelId, createdAt])
  @@index([userId, createdAt])
  @@index([workflowRunId])
  @@index([nodeRunId])
  @@index([providerTaskUuid])
}

model Admin {
  id             String        @id @default(uuid())
  username       String        @unique
  displayName    String
  passwordHash   String
  active         Boolean       @default(true)
  sessionVersion Int           @default(0)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  session        AdminSession?
}

model AdminSession {
  id        String   @id @default(uuid())
  adminId   String   @unique
  tokenHash String   @unique
  version   Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @unique
  tokenHash String   @unique
  version   Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmsVerificationCode {
  id          String    @id @default(uuid())
  countryCode String    @default("+86")
  phone       String
  codeHash    String
  role        Role
  attempts    Int       @default(0)
  consumedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([countryCode, phone, createdAt])
}

model Workflow {
  id          String            @id @default(uuid())
  ownerId     String
  name        String
  description String?
  definition  Json
  activeRunId String?           @unique
  lockedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  versions    WorkflowVersion[]
  runs        WorkflowRun[]     @relation("WorkflowRuns")
  activeRun   WorkflowRun?      @relation("ActiveWorkflowRun", fields: [activeRunId], references: [id], onDelete: SetNull)

  @@index([ownerId, updatedAt])
}

model WorkflowVersion {
  id         String        @id @default(uuid())
  workflowId String
  number     Int
  definition Json
  createdAt  DateTime      @default(now())
  workflow   Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  runs       WorkflowRun[]

  @@unique([workflowId, number])
}

model WorkflowRun {
  id             String            @id @default(uuid())
  workflowId     String
  versionId      String?
  userId         String
  status         RunStatus         @default(PENDING)
  cost           Int               @default(0)
  error          String?
  durationMs     Int?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime          @default(now())
  workflow       Workflow          @relation("WorkflowRuns", fields: [workflowId], references: [id])
  version        WorkflowVersion?  @relation(fields: [versionId], references: [id])
  lockedWorkflow Workflow?         @relation("ActiveWorkflowRun")
  user           User              @relation(fields: [userId], references: [id])
  nodeRuns       NodeRun[]
  reservation    PointReservation?
  aiInvocations  AiModelInvocation[]

  @@index([userId, createdAt])
}

model NodeRun {
  id           String        @id @default(uuid())
  runId        String
  nodeKey      String
  nodeType     String
  cost         Int           @default(0)
  status       NodeRunStatus @default(PENDING)
  input        Json?
  output       Json?
  error        String?
  errorDetails Json?
  attempt      Int           @default(0)
  durationMs   Int?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime      @default(now())
  run          WorkflowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  aiInvocations AiModelInvocation[]

  @@unique([runId, nodeKey])
  @@index([runId, status])
}

model PointAccount {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  frozen    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointLedger {
  id           String     @id @default(uuid())
  userId       String
  type         LedgerType
  amount       Int
  balanceAfter Int
  referenceId  String?
  description  String?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, referenceId])
  @@index([userId, createdAt])
}

model PointReservation {
  id        String      @id @default(uuid())
  runId     String      @unique
  userId    String
  amount    Int
  settled   Int         @default(0)
  released  Int         @default(0)
  createdAt DateTime    @default(now())
  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model PaymentOrder {
  id              String           @id @default(uuid())
  orderNo         String           @unique
  userId          String
  channel         PaymentChannel
  status          PaymentStatus    @default(PENDING)
  amountFen       Int
  keys            Int              @map("points")
  packageId       String?
  qrUrl           String?
  providerTradeNo String?          @unique
  paidAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
  package         RechargePackage? @relation(fields: [packageId], references: [id])
  events          PaymentEvent[]

  @@index([userId, createdAt])
}

model PaymentEvent {
  id        String       @id @default(uuid())
  orderId   String
  eventKey  String       @unique
  payload   Json
  createdAt DateTime     @default(now())
  order     PaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
